"use client";

import { useRouter } from "next/navigation";

export default function CloseArcadeButton() {
  const router = useRouter();

  const handleClose = () => {
    // Try to close the tab
    window.close();

    // If the browser doesn't allow it,
    // return to the homepage after a short delay.
    setTimeout(() => {
      router.push("/");
    }, 150);
  };

  return (
    <button
      type="button"
      onClick={handleClose}
      className="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-5 py-3 text-xs font-bold uppercase tracking-[0.25em] text-white/60 transition hover:border-[#62ff00] hover:text-[#62ff00]"
    >
      ✕ Close Arcade
    </button>
  );
}